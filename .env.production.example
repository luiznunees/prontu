# IA (Gemini & HuggingFace)
GEMINI_API_KEY=
# Token para geração de imagens (HuggingFace)
# Gerar em: https://huggingface.co/settings/tokens
HF_TOKEN=

# Unsplash (Imagens)
# Pegar chave em: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Supabase (Produção)
# IMPORTANTE: Use um projeto Supabase diferente para produção
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AbacatePay (Produção)
ABACATEPAY_TOKEN=
ABACATEPAY_BASE_URL=https://api.abacatepay.com
ABACATEPAY_WEBHOOK_SECRET=

# Upstash Redis (Rate Limiting)
# Criar database Redis no upstash.com e copiar credenciais
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App Config
NEXT_PUBLIC_APP_URL=https://useprontu.online
NEXT_PUBLIC_APP_NAME=Prontu
